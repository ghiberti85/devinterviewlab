# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# !! NEVER put SUPABASE_SERVICE_ROLE_KEY in NEXT_PUBLIC_ variables !!
# SUPABASE_SERVICE_ROLE_KEY=   ← keep this server-only, never expose

# ── AI Provider (Groq is free tier — recommended) ────────────────────────────
# Get your free key at: https://console.groq.com
OPENAI_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.3-70b-versatile   # optional, auto-detected from base URL

# ── Sentry Error Monitoring (free tier — optional but recommended) ────────────
# Sign up at: https://sentry.io (free: 5,000 errors/month)
# 1. Create project → Next.js
# 2. Copy DSN from Project Settings → Client Keys
SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx
NEXT_PUBLIC_SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx
# (same value for both — SENTRY_DSN for server, NEXT_PUBLIC_ for client)

# SENTRY_AUTH_TOKEN is only needed for source maps upload during build
# SENTRY_AUTH_TOKEN=sntrys_xxxx
